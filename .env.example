# Builder Guide live model.
# The /api/guide route tries Cerebras first (it is the faster inference), then
# falls back to Groq if Cerebras is missing, rate limited, or erroring. You only
# need one key, but adding both gives you a fallback.
#
# Copy this file to .env.local and paste your keys, then restart the dev server.
# Never commit .env.local. With no key set the guide still runs on an offline
# script.

# Cerebras: https://cloud.cerebras.ai  ->  API Keys
CEREBRAS_API_KEY=

# Groq: https://console.groq.com/keys
GROQ_API_KEY=

# Optional model overrides (defaults shown, both are fast current models)
# CEREBRAS_MODEL=llama-3.3-70b
# GROQ_MODEL=llama-3.3-70b-versatile
